{
  "name": "lang-mirror",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:client": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "mock-oidc": "lsof -ti :7843 2>/dev/null | xargs kill -9 2>/dev/null; bun scripts/mock-oidc/server.ts",
    "cf:dev": "bun run cf:migrate && concurrently \"bun run dev:client\" \"wrangler dev --local\" \"bun run mock-oidc\"",
    "cf:deploy": "vite build && wrangler deploy",
    "cf:schema:gen": "bun scripts/generate-schema.ts",
    "cf:migrate": "bun run cf:schema:gen && wrangler d1 migrations apply lang-mirror-db --local && wrangler d1 execute lang-mirror-db --local --file=scripts/seed-mock-oidc.sql",
    "cf:migrate:remote": "bun run cf:schema:gen && wrangler d1 migrations apply lang-mirror-db --remote",
    "cf:migrate:list": "wrangler d1 migrations list lang-mirror-db --local",
    "clean:cf": "lsof -ti :7842 2>/dev/null | xargs kill -9 2>/dev/null; lsof -ti :7843 2>/dev/null | xargs kill -9 2>/dev/null; rm -rf .wrangler/state && echo '✓ CF local state cleared (D1 + R2 + KV + ports)'"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.163",
    "@cloudflare/ai-chat": "^0.4.3",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5",
    "@tanstack/react-router": "^1",
    "agents": "^0.11.0",
    "ai": "^6.0.161",
    "hono": "^4.12.12",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "workers-ai-provider": "^3.1.10",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260409.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vite": "^8.0.8",
    "wrangler": "^4.81.0"
  }
}
