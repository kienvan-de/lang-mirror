{
  "name": "lang-mirror",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "NODE_ENV=development bun --watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "bun src/server/index.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "cf:dev": "bun run cf:migrate && concurrently \"bun run dev:client\" \"wrangler dev --local\"",
    "cf:deploy": "vite build && wrangler deploy",
    "cf:migrate": "wrangler d1 migrations apply lang-mirror-db --local",
    "cf:migrate:remote": "wrangler d1 migrations apply lang-mirror-db --remote",
    "cf:migrate:list": "wrangler d1 migrations list lang-mirror-db --local",

    "clean:dev": "rm -f ~/.lang-mirror/db.sqlite ~/.lang-mirror/db.sqlite-shm ~/.lang-mirror/db.sqlite-wal && echo '✓ Desktop DB cleared'",
    "clean:dev:all": "rm -rf ~/.lang-mirror/db.sqlite ~/.lang-mirror/db.sqlite-shm ~/.lang-mirror/db.sqlite-wal ~/.lang-mirror/cache ~/.lang-mirror/recordings && echo '✓ Desktop DB + cache + recordings cleared'",

    "clean:cf": "rm -rf .wrangler/state && echo '✓ CF local state cleared (D1 + R2 + KV)'",

    "clean:all": "bun run clean:dev:all && bun run clean:cf"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5",
    "@tanstack/react-router": "^1",
    "hono": "^4.12.12",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "js-yaml": "^4",
    "node-edge-tts": "latest",
    "react": "^18",
    "react-dom": "^18",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "zustand": "^4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260409.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "latest",
    "@types/js-yaml": "^4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "concurrently": "^8",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5",
    "vite": "^5",
    "wrangler": "^4.81.0"
  }
}
